# Database (async SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vrr

# App
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
BACKEND_CORS_ORIGINS=http://localhost:3000

# Admin bootstrap (one-time create first admin)
ADMIN_BOOTSTRAP_TOKEN=change-me-bootstrap-secret

# Optional: local script `scripts/seed_admin.py` (or ADMIN_EMAIL / ADMIN_PASSWORD on Railway)
# ADMIN_SEED_EMAIL=
# ADMIN_SEED_PASSWORD=

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Rate limiting (slowapi)
RATE_LIMIT_PUBLIC_POST=10/minute

# R2 / S3-compatible uploads (optional)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_BASE_URL=

# Stripe (test keys; use GoFundMe until 501c3 resolved)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# hCaptcha (optional; public POSTs)
HCAPTCHA_SECRET=

# Cron (featured vendor rotation)
CRON_SECRET=

# Email domain blocklist (comma-separated)
EMAIL_DOMAIN_BLOCKLIST=
